# Leave empty (or remove) to call API via Next.js proxy rewrites
NEXT_PUBLIC_API_BASE_URL=
# Backend target for Next.js server-side proxy
API_PROXY_TARGET=http://localhost:8080

NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8082
NEXT_PUBLIC_KEYCLOAK_REALM=comics-realm
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=comics-web
