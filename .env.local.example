# Leave empty (or remove) to call API via Next.js proxy rewrites
NEXT_PUBLIC_API_BASE_URL=http://api.localhost
# Backend target for Next.js server-side proxy
API_PROXY_TARGET=

NEXT_PUBLIC_KEYCLOAK_URL=http://auth.localhost
NEXT_PUBLIC_KEYCLOAK_REALM=comics
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=comics-frontend
